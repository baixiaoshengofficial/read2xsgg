{
  "name": "read2xsgg",
  "version": "0.2.0",
  "description": "将阅读（Legado）书源转换为香色闺阁 JSON/XBS 书源",
  "type": "module",
  "bin": {
    "read2xsgg": "./bin/read2xsgg.js",
    "read2xsgg-server": "./bin/server.js",
    "read2xsgg-validate": "./bin/validate-xbs.js",
    "read2xsgg-publish-library": "./bin/publish-library.js"
  },
  "exports": "./src/index.js",
  "scripts": {
    "test": "node --test",
    "test:live": "RUN_LIVE_TESTS=1 node --test test/live-alicesw.test.js",
    "test:xbs-live": "RUN_XBS_LIVE=1 node --test test/live-xbs.test.js",
    "validate:xbs": "node ./bin/validate-xbs.js",
    "convert": "node ./bin/read2xsgg.js",
    "publish:library": "node ./bin/publish-library.js",
    "start": "node ./bin/server.js",
    "docker:push": "./scripts/docker-push.sh"
  },
  "keywords": [
    "legado",
    "xsreader",
    "xbs",
    "书源"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "jimp": "^1.6.1",
    "jsdom": "^24.1.3"
  }
}
